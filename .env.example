# ──────────────────────────────────────────────
# Souqona Environment Configuration
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# ── PostgreSQL (with pgvector for RAG) ────────
POSTGRES_USER=souqona
POSTGRES_PASSWORD=souqona_secret
POSTGRES_DB=souqona_db
POSTGRES_PORT=5432

# ── Database URL (used by Prisma) ─────────────
# In Docker: host is the service name "db"
# Locally:   host is "localhost"
DATABASE_URL=postgresql://souqona:souqona_secret@db:5432/souqona_db?schema=public

# ── Node.js API (the Brain) ──────────────────
API_PORT=3001
NODE_ENV=development

# ── Groq AI (for Chat LLM) ────────────────────
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Gemini AI (for RAG Embeddings) ────────────
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Next.js Frontend ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_PORT=3000
