                    { "key": "alt", "type": "text", "value": "Variant photo" }
                  ]
                }
              }
            },
            {
              "name": "[Admin] Update Variant Image",
              "request": {
                "method": "PATCH",
                "url": "{{baseUrl}}/api/images/variant/{{variantId}}/{{imageId}}",
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
