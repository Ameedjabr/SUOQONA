{
  "info": {
    "name": "Souqona E-Commerce API",
    "description": "Complete API collection for Souqona e-commerce platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "accessToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "targetUserId", "value": "" },
    { "key": "addressId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "variantId", "value": "" },
    { "key": "cartItemId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "imageId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('userId', res.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@test.com\",\n  \"password\": \"Test@1234\",\n  \"fullName\": \"Test Customer\"\n}"
            }
          }
        },
        {
          "name": "Login (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('userId', res.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@test.com\",\n  \"password\": \"Test@1234\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('adminToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@souqona.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/refresh",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Request Password Reset",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/password-reset/request",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@test.com\"\n}"
            }
          }
        },
        {
          "name": "Confirm Password Reset",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/password-reset/confirm",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PASTE_TOKEN_HERE\",\n  \"newPassword\": \"NewPass@123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "User (Self-Service)",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/users/me",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Updated Name\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users (Admin)",
      "item": [
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "role", "value": "CUSTOMER", "disabled": true },
                { "key": "isActive", "value": "true", "disabled": true },
                { "key": "q", "value": "", "disabled": true }
              ]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          }
        },
        {
          "name": "Get User by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('targetUserId', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/{{targetUserId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          }
        },
        {
          "name": "Update User (Role/Status)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/users/{{targetUserId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"ADMIN\",\n  \"isActive\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Addresses",
      "item": [
        {
          "name": "List My Addresses",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/addresses"
          }
        },
        {
          "name": "Create Address",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('addressId', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/addresses",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Home\",\n  \"fullName\": \"Test Customer\",\n  \"phonePrimary\": \"+972501234567\",\n  \"phoneSecondary\": \"+972509876543\",\n  \"country\": \"Palestine\",\n  \"city\": \"Ramallah\",\n  \"area\": \"Al-Masyoun\",\n  \"addressLine1\": \"123 Main Street\",\n  \"addressLine2\": \"Building 4, Floor 2\",\n  \"postalCode\": \"12345\",\n  \"isDefault\": true\n}"
            }
          }
        },
        {
          "name": "Get Address",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/addresses/{{addressId}}"
          }
        },
        {
          "name": "Update Address",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/addresses/{{addressId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Work\",\n  \"city\": \"Nablus\"\n}"
            }
          }
        },
        {
          "name": "Delete Address",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/addresses/{{addressId}}"
          }
        }
      ]
    },
    {
      "name": "Categories (Public)",
      "item": [
        {
          "name": "List All Categories (Tree)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Category by Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories/electronics",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Categories (Admin)",
      "item": [
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('categoryId', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/categories",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Smartphones\",\n  \"parentId\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/categories/{{categoryId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Category Name\"\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/categories/{{categoryId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          }
        }
      ]
    },
    {
      "name": "Products (Public)",
      "item": [
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "q", "value": "", "disabled": true },
                { "key": "category", "value": "electronics", "disabled": true },
                { "key": "brand", "value": "SoundTech", "disabled": true },
                { "key": "minPrice", "value": "1000", "disabled": true },
                { "key": "maxPrice", "value": "50000", "disabled": true },
                { "key": "status", "value": "ACTIVE", "disabled": true }
              ]
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Product by Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/slug/wireless-bluetooth-headphones",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/{{productId}}",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Products (Admin)",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('productId', res.data.id);",
                  "  if (res.data.variants && res.data.variants.length > 0) {",
                  "    pm.collectionVariables.set('variantId', res.data.variants[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Wireless Mouse\",\n  \"description\": \"Ergonomic wireless mouse with USB-C receiver\",\n  \"brand\": \"TechGear\",\n  \"priceCents\": 7900,\n  \"compareAtPriceCents\": 9900,\n  \"currency\": \"ILS\",\n  \"status\": \"DRAFT\"\n}"
            }
          }
        },
        {
          "name": "Update Product (with Categories)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/products/{{productId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Product Title\",\n  \"priceCents\": 8500,\n  \"status\": \"ACTIVE\",\n  \"categoryIds\": [\"{{categoryId}}\"]\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/products/{{productId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          }
        }
      ]
    },
    {
      "name": "Variants",
