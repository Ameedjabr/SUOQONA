              "mode": "raw",
              "raw": "{\n  \"sku\": \"NEW-VAR-001\",\n  \"barcode\": \"7290000000001\",\n  \"priceCents\": 9900,\n  \"compareAtPriceCents\": 12900,\n  \"currency\": \"ILS\",\n  \"optionValues\": { \"color\": \"Red\", \"size\": \"XL\" },\n  \"initialStock\": 50\n}"
            }
          }
        },
