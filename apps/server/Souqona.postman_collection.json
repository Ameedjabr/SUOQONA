    {
      "name": "Images (File Upload)",
      "item": [
        {
          "name": "Product Images",
          "item": [
            {
              "name": "List Product Images",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/api/images/product/{{productId}}",
                "auth": { "type": "noauth" }
              }
            },
            {
              "name": "[Admin] Upload Product Images",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const res = pm.response.json();",
                      "if (res.success && res.data && res.data.length > 0) {",
                      "  pm.collectionVariables.set('imageId', res.data[0].id);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/api/images/product/{{productId}}",
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "images", "type": "file", "src": "", "description": "Select image file(s)" },
                    { "key": "images", "type": "file", "src": "", "description": "Second image (optional)", "disabled": true },
                    { "key": "alt", "type": "text", "value": "Product photo" }
                  ]
                }
              }
            },
            {
              "name": "[Admin] Update Product Image",
              "request": {
                "method": "PATCH",
                "url": "{{baseUrl}}/api/images/product/{{productId}}/{{imageId}}",
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"alt\": \"Updated product image alt\",\n  \"sortOrder\": 1\n}"
                }
              }
            },
            {
              "name": "[Admin] Delete Product Image",
              "request": {
                "method": "DELETE",
                "url": "{{baseUrl}}/api/images/product/{{productId}}/{{imageId}}",
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
              }
            }
